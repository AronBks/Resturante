// ============================================================
// SGGI — Prisma Schema (Cleaned)
// Sistema de Gestión Gastronómica Inteligente
//
// Modelo relacional simplificado para flujo diario sin inventario:
// - Usuario, Mesa, Pedido, DetallePedido, Plato
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// USUARIOS Y AUTENTICACIÓN
// ─────────────────────────────────────────────

enum RolUsuario {
  ADMIN
  CAJERO
  MESERO
  CHEF
}

model Usuario {
  id           String   @id @default(uuid()) @db.Uuid
  nombre       String   @db.VarChar(100)
  email        String   @unique @db.VarChar(150)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  rol          RolUsuario
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relaciones
  pedidos       Pedido[]
  cajasAbiertas Caja[]

  @@map("usuarios")
}

// ─────────────────────────────────────────────
// MESAS — Layout del Restaurante Diario
// ─────────────────────────────────────────────

enum EstadoMesa {
  LIBRE
  OCUPADA
  POR_COBRAR
}

model Mesa {
  id        Int        @id @default(autoincrement())
  numero    String     @unique @db.VarChar(10)
  capacidad Int        @default(4)
  estado    EstadoMesa @default(LIBRE)
  /// Coordenadas {x, y, zona} para el mapa visual interactivo
  posicion  Json       @default("{\"x\": 0, \"y\": 0, \"zona\": \"Zona Central\"}")
  activa    Boolean    @default(true)
  createdAt DateTime   @default(now()) @map("created_at")

  // Relaciones
  pedidos Pedido[]

  @@map("mesas")
}

// ─────────────────────────────────────────────
// CARTA — Categorías y Platos
// ─────────────────────────────────────────────

model CategoriaPlato {
  id          Int     @id @default(autoincrement())
  nombre      String  @unique @db.VarChar(80)
  descripcion String? @db.VarChar(255)
  /// Orden de aparición en el menú
  orden       Int     @default(0)
  activa      Boolean @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  // Relaciones
  platos Plato[]

  @@map("categorias_plato")
}

model Plato {
  id           String   @id @default(uuid()) @db.Uuid
  nombre       String   @db.VarChar(120)
  descripcion  String?  @db.VarChar(500)
  precioVenta  Decimal  @map("precio_venta") @db.Decimal(10, 2)
  imagenUrl    String?  @map("imagen_url") @db.VarChar(500)
  disponible   Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // FK
  categoriaId  Int      @map("categoria_id")
  categoria    CategoriaPlato @relation(fields: [categoriaId], references: [id])

  // Relaciones
  detallesPedido  DetallePedido[]

  @@index([categoriaId])
  @@index([disponible])
  @@map("platos")
}

// ─────────────────────────────────────────────
// PEDIDOS — Ciclo de Vida Completo
// ─────────────────────────────────────────────

enum EstadoPedido {
  ABIERTO
  EN_COCINA
  LISTO
  ENTREGADO
  CANCELADO
}

model Pedido {
  id         String       @id @default(uuid()) @db.Uuid
  estado     EstadoPedido @default(ABIERTO)
  subtotal   Decimal      @default(0) @db.Decimal(10, 2)
  descuento  Decimal      @default(0) @db.Decimal(10, 2)
  total      Decimal      @default(0) @db.Decimal(10, 2)
  notas      String?      @db.VarChar(500)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  // FKs
  mesaId    Int     @map("mesa_id")
  mesa      Mesa    @relation(fields: [mesaId], references: [id])
  meseroId  String  @map("mesero_id") @db.Uuid
  mesero    Usuario @relation(fields: [meseroId], references: [id])

  // Relaciones
  detalles     DetallePedido[]
  transacciones Transaccion[]

  @@index([mesaId])
  @@index([meseroId])
  @@index([estado])
  @@index([createdAt])
  @@map("pedidos")
}

enum EstadoItemPedido {
  PENDIENTE
  PREPARANDO
  LISTO
  ENTREGADO
  CANCELADO
}

model DetallePedido {
  id             String          @id @default(uuid()) @db.Uuid
  cantidad       Int
  /// Snapshot: precio del plato al momento de ordenar (inmutable)
  precioUnitario Decimal         @map("precio_unitario") @db.Decimal(10, 2)
  notas          String?         @db.VarChar(255)
  estadoItem     EstadoItemPedido @default(PENDIENTE) @map("estado_item")
  createdAt      DateTime        @default(now()) @map("created_at")

  // FKs
  pedidoId String @map("pedido_id") @db.Uuid
  pedido   Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  platoId  String @map("plato_id") @db.Uuid
  plato    Plato  @relation(fields: [platoId], references: [id])

  @@index([pedidoId])
  @@index([estadoItem])
  @@map("detalles_pedido")
}

// ─────────────────────────────────────────────
// CAJA — Turnos y Transacciones
// ─────────────────────────────────────────────

enum EstadoCaja {
  ABIERTA
  CERRADA
}

model Caja {
  id            String    @id @default(uuid()) @db.Uuid
  montoApertura Decimal   @map("monto_apertura") @db.Decimal(10, 2)
  montoCierre   Decimal?  @map("monto_cierre") @db.Decimal(10, 2)
  totalVentas   Decimal   @default(0) @map("total_ventas") @db.Decimal(10, 2)
  totalEfectivo Decimal   @default(0) @map("total_efectivo") @db.Decimal(10, 2)
  totalTarjeta  Decimal   @default(0) @map("total_tarjeta") @db.Decimal(10, 2)
  totalQr       Decimal   @default(0) @map("total_qr") @db.Decimal(10, 2)
  estado        EstadoCaja @default(ABIERTA)
  apertura      DateTime  @default(now())
  cierre        DateTime?
  createdAt     DateTime  @default(now()) @map("created_at")

  // FKs
  usuarioId String  @map("usuario_id") @db.Uuid
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  // Relaciones
  transacciones Transaccion[]

  @@index([estado])
  @@index([apertura])
  @@map("cajas")
}

enum MetodoPago {
  EFECTIVO
  TARJETA
  QR
  MIXTO
}

model Transaccion {
  id          String     @id @default(uuid()) @db.Uuid
  monto       Decimal    @db.Decimal(10, 2)
  metodoPago  MetodoPago @map("metodo_pago")
  cambio      Decimal    @default(0) @db.Decimal(10, 2)
  nit         String?    @db.VarChar(50)
  razonSocial String?    @map("razon_social") @db.VarChar(150)
  createdAt   DateTime   @default(now()) @map("created_at")

  // FKs
  cajaId    String @map("caja_id") @db.Uuid
  caja      Caja   @relation(fields: [cajaId], references: [id])
  pedidoId  String @map("pedido_id") @db.Uuid
  pedido    Pedido @relation(fields: [pedidoId], references: [id])

  @@index([cajaId])
  @@index([createdAt])
  @@map("transacciones")
}
