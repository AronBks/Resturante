// ============================================================
// SGGI — Prisma Schema
// Sistema de Gestión Gastronómica Inteligente
//
// Modelo relacional completo con:
// - UUIDs para entidades de negocio
// - Integers para catálogos estáticos
// - Snapshots de precios para integridad histórica
// - Event Sourcing simplificado en inventario
// - Índices optimizados para queries analíticos
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// USUARIOS Y AUTENTICACIÓN
// ─────────────────────────────────────────────

enum RolUsuario {
  ADMIN
  CAJERO
  MESERO
  CHEF
}

model Usuario {
  id           String   @id @default(uuid()) @db.Uuid
  nombre       String   @db.VarChar(100)
  email        String   @unique @db.VarChar(150)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  rol          RolUsuario
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relaciones
  pedidos                Pedido[]
  cajasAbiertas          Caja[]
  movimientosInventario  MovimientoInventario[]

  @@map("usuarios")
}

// ─────────────────────────────────────────────
// MESAS — Layout del Restaurante
// ─────────────────────────────────────────────

enum EstadoMesa {
  LIBRE
  OCUPADA
  RESERVADA
  POR_COBRAR
}

model Mesa {
  id        Int        @id @default(autoincrement())
  numero    String     @unique @db.VarChar(10)
  capacidad Int        @default(4)
  estado    EstadoMesa @default(LIBRE)
  /// Coordenadas {x, y, rotacion} para el mapa visual interactivo
  posicion  Json       @default("{\"x\": 0, \"y\": 0, \"rotacion\": 0}")
  activa    Boolean    @default(true)
  createdAt DateTime   @default(now()) @map("created_at")

  // Relaciones
  pedidos Pedido[]

  @@map("mesas")
}

// ─────────────────────────────────────────────
// CARTA — Categorías, Platos y Recetas
// ─────────────────────────────────────────────

model CategoriaPlato {
  id          Int     @id @default(autoincrement())
  nombre      String  @unique @db.VarChar(80)
  descripcion String? @db.VarChar(255)
  /// Orden de aparición en el menú
  orden       Int     @default(0)
  activa      Boolean @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  // Relaciones
  platos Plato[]

  @@map("categorias_plato")
}

model Plato {
  id           String   @id @default(uuid()) @db.Uuid
  nombre       String   @db.VarChar(120)
  descripcion  String?  @db.VarChar(500)
  precioVenta  Decimal  @map("precio_venta") @db.Decimal(10, 2)
  imagenUrl    String?  @map("imagen_url") @db.VarChar(500)
  disponible   Boolean  @default(true)
  /// Costo calculado a partir de la receta (Σ ingredientes × precio unitario)
  costoReceta  Decimal  @default(0) @map("costo_receta") @db.Decimal(10, 2)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // FK
  categoriaId  Int      @map("categoria_id")
  categoria    CategoriaPlato @relation(fields: [categoriaId], references: [id])

  // Relaciones
  recetaDetalles  RecetaDetalle[]
  detallesPedido  DetallePedido[]

  @@index([categoriaId])
  @@index([disponible])
  @@map("platos")
}

// ─────────────────────────────────────────────
// INVENTARIO — Ingredientes y Recetario Dinámico
// ─────────────────────────────────────────────

enum UnidadMedida {
  KG
  G
  L
  ML
  UNIDAD
}

model Ingrediente {
  id             String      @id @default(uuid()) @db.Uuid
  nombre         String      @unique @db.VarChar(120)
  unidadMedida   UnidadMedida @map("unidad_medida")
  stockActual    Decimal     @default(0) @map("stock_actual") @db.Decimal(12, 4)
  /// Nivel por debajo del cual se genera alerta amarilla
  umbralMinimo   Decimal     @default(0) @map("umbral_minimo") @db.Decimal(12, 4)
  /// Nivel por debajo del cual se desactivan platos asociados
  umbralCritico  Decimal     @default(0) @map("umbral_critico") @db.Decimal(12, 4)
  /// Costo por unidad de medida (Ej: precio por KG)
  precioUnitario Decimal     @default(0) @map("precio_unitario") @db.Decimal(10, 4)
  activo         Boolean     @default(true)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")

  // Relaciones
  recetaDetalles  RecetaDetalle[]
  movimientos     MovimientoInventario[]

  @@map("ingredientes")
}

/// Tabla pivote: composición de un plato (receta)
model RecetaDetalle {
  id                String      @id @default(uuid()) @db.Uuid
  cantidadRequerida Decimal     @map("cantidad_requerida") @db.Decimal(10, 4)
  unidad            UnidadMedida

  // FKs
  platoId       String      @map("plato_id") @db.Uuid
  plato         Plato       @relation(fields: [platoId], references: [id], onDelete: Cascade)
  ingredienteId String      @map("ingrediente_id") @db.Uuid
  ingrediente   Ingrediente @relation(fields: [ingredienteId], references: [id], onDelete: Cascade)

  @@unique([platoId, ingredienteId])
  @@map("recetas_detalle")
}

// ─────────────────────────────────────────────
// MOVIMIENTOS DE INVENTARIO (Event Sourcing simplificado)
// Cada movimiento es inmutable y mantiene un snapshot del stock resultante.
// ─────────────────────────────────────────────

enum TipoMovimientoInventario {
  ENTRADA
  SALIDA_VENTA
  SALIDA_MERMA
  AJUSTE
}

model MovimientoInventario {
  id              String                  @id @default(uuid()) @db.Uuid
  tipo            TipoMovimientoInventario
  cantidad        Decimal                 @db.Decimal(12, 4)
  /// Snapshot del stock después de aplicar el movimiento
  stockResultante Decimal                 @map("stock_resultante") @db.Decimal(12, 4)
  /// Referencia cruzada: pedido_id para ventas, nota para manuales
  referencia      String?                 @db.VarChar(255)
  createdAt       DateTime                @default(now()) @map("created_at")

  // FKs
  ingredienteId String      @map("ingrediente_id") @db.Uuid
  ingrediente   Ingrediente @relation(fields: [ingredienteId], references: [id])
  usuarioId     String      @map("usuario_id") @db.Uuid
  usuario       Usuario     @relation(fields: [usuarioId], references: [id])

  @@index([ingredienteId, createdAt])
  @@index([tipo])
  @@map("movimientos_inventario")
}

// ─────────────────────────────────────────────
// PEDIDOS — Ciclo de Vida Completo
// ─────────────────────────────────────────────

enum EstadoPedido {
  ABIERTO
  EN_COCINA
  LISTO
  ENTREGADO
  CANCELADO
}

model Pedido {
  id         String       @id @default(uuid()) @db.Uuid
  estado     EstadoPedido @default(ABIERTO)
  subtotal   Decimal      @default(0) @db.Decimal(10, 2)
  descuento  Decimal      @default(0) @db.Decimal(10, 2)
  total      Decimal      @default(0) @db.Decimal(10, 2)
  notas      String?      @db.VarChar(500)
  createdAt  DateTime     @default(now()) @map("created_at")
  updatedAt  DateTime     @updatedAt @map("updated_at")

  // FKs
  mesaId    Int     @map("mesa_id")
  mesa      Mesa    @relation(fields: [mesaId], references: [id])
  meseroId  String  @map("mesero_id") @db.Uuid
  mesero    Usuario @relation(fields: [meseroId], references: [id])

  // Relaciones
  detalles     DetallePedido[]
  transacciones Transaccion[]

  @@index([mesaId])
  @@index([meseroId])
  @@index([estado])
  @@index([createdAt])
  @@map("pedidos")
}

enum EstadoItemPedido {
  PENDIENTE
  PREPARANDO
  LISTO
  ENTREGADO
  CANCELADO
}

model DetallePedido {
  id             String          @id @default(uuid()) @db.Uuid
  cantidad       Int
  /// Snapshot: precio del plato al momento de ordenar (inmutable)
  precioUnitario Decimal         @map("precio_unitario") @db.Decimal(10, 2)
  notas          String?         @db.VarChar(255)
  estadoItem     EstadoItemPedido @default(PENDIENTE) @map("estado_item")
  createdAt      DateTime        @default(now()) @map("created_at")

  // FKs
  pedidoId String @map("pedido_id") @db.Uuid
  pedido   Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  platoId  String @map("plato_id") @db.Uuid
  plato    Plato  @relation(fields: [platoId], references: [id])

  @@index([pedidoId])
  @@index([estadoItem])
  @@map("detalles_pedido")
}

// ─────────────────────────────────────────────
// CAJA — Turnos y Transacciones
// ─────────────────────────────────────────────

enum EstadoCaja {
  ABIERTA
  CERRADA
}

model Caja {
  id            String    @id @default(uuid()) @db.Uuid
  montoApertura Decimal   @map("monto_apertura") @db.Decimal(10, 2)
  montoCierre   Decimal?  @map("monto_cierre") @db.Decimal(10, 2)
  totalVentas   Decimal   @default(0) @map("total_ventas") @db.Decimal(10, 2)
  totalEfectivo Decimal   @default(0) @map("total_efectivo") @db.Decimal(10, 2)
  totalTarjeta  Decimal   @default(0) @map("total_tarjeta") @db.Decimal(10, 2)
  totalQr       Decimal   @default(0) @map("total_qr") @db.Decimal(10, 2)
  estado        EstadoCaja @default(ABIERTA)
  apertura      DateTime  @default(now())
  cierre        DateTime?
  createdAt     DateTime  @default(now()) @map("created_at")

  // FKs
  usuarioId String  @map("usuario_id") @db.Uuid
  usuario   Usuario @relation(fields: [usuarioId], references: [id])

  // Relaciones
  transacciones Transaccion[]

  @@index([estado])
  @@index([apertura])
  @@map("cajas")
}

enum MetodoPago {
  EFECTIVO
  TARJETA
  QR
  MIXTO
}

model Transaccion {
  id         String     @id @default(uuid()) @db.Uuid
  monto      Decimal    @db.Decimal(10, 2)
  metodoPago MetodoPago @map("metodo_pago")
  cambio     Decimal    @default(0) @db.Decimal(10, 2)
  createdAt  DateTime   @default(now()) @map("created_at")

  // FKs
  cajaId    String @map("caja_id") @db.Uuid
  caja      Caja   @relation(fields: [cajaId], references: [id])
  pedidoId  String @map("pedido_id") @db.Uuid
  pedido    Pedido @relation(fields: [pedidoId], references: [id])

  @@index([cajaId])
  @@index([createdAt])
  @@map("transacciones")
}
