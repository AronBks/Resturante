# ── PostgreSQL ──
POSTGRES_USER=sggi_admin
POSTGRES_PASSWORD=sggi_dev_2026
POSTGRES_DB=sggi_db
POSTGRES_PORT=5433
DATABASE_URL=postgresql://sggi_admin:sggi_dev_2026@127.0.0.1:5433/sggi_db?schema=public

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379
