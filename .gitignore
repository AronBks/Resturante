# ============================================================
# SGGI Monorepo — .gitignore
# ============================================================

# ── Dependencies ──
node_modules/
.npm

# ── Build outputs ──
dist/
build/
.angular/
.next/

# ── Environment ──
.env
.env.local
.env.*.local

# ── IDE ──
.idea/
.vscode/
*.swp
*.swo
*~

# ── OS ──
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ──
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# ── Testing ──
coverage/
.nyc_output/

# ── Prisma ──
backend/prisma/*.db
backend/prisma/*.db-journal

# ── Docker volumes (local) ──
docker/data/

# ── Misc ──
*.tsbuildinfo
.eslintcache
